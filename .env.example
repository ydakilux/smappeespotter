# Weather API (Open Weather Map)
VITE_OPENWEATHERMAP_API_KEY=your_owm_api_key_here

# Gemini API (for AI locations extraction)
GEMINI_API_KEY=

# Météo-France Authentication
# Option 1: Use your Application ID (base64 string) to automatically fetch and refresh tokens
METEO_FRANCE_APP_ID=your_meteo_france_app_id_base64_here
# Option 2 (Legacy): Use a 1-hour token directly
VITE_METEO_FRANCE_TOKEN=your_meteo_france_token_here
